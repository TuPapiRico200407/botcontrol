{
  "name": "botcontrol-monorepo",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --parallel -r run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm --parallel -r run lint",
    "typecheck": "pnpm --parallel -r run typecheck",
    "test": "pnpm --parallel -r run test",
    "e2e": "pnpm --parallel -r run e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "deploy:web": "pnpm --filter web run deploy",
    "deploy:api": "pnpm --filter api-worker run deploy",
    "db:migrate": "cd supabase && supabase db push",
    "db:seed": "cd supabase && supabase db reset"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
